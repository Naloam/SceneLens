      "headlines": [
        "到公司了，准备开始新的一天！",
        "{greeting}，工作日开始",
        "检测到办公室环境，进入工作模式",
        "周{weekday_name}早上好，{encouragement}！",
        "办公室场景识别，工作模式启动",
        "到岗了，开启专注工作"
      ],
      "subtexts": [
        "已连接办公网络",
        "今天有什么重要任务？",
        "工作模式已就绪",
        "周{weekday_name}工作日",
        "开始新的一天"
      ],
      "actionReasons": {
        "DND": [
          "工作时间开启勿扰，专注办公",
          "减少打扰，提高效率",
          "工作模式，仅保留重要通知"
        ],
        "CALENDAR": [
          "查看今日日程安排",
