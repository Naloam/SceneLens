  "slotFillers": {
    "quiet_level": {
      "conditions": [
        { "when": "audio.soundEnvironment === 'quiet'", "value": "非常安静" },
        { "when": "audio.soundEnvironment === 'moderate'", "value": "适中" },
        { "default": "有些嘈杂" }
      ]
    }
  }
