    },
    {
      "id": "OFFICE_OVERTIME",
      "conditions": [
        "time.isWorkday",
        "time.hour >= 19"
      ],
      "headlines": [
        "还在加班吗？别忘了休息一下",
        "已经{hour}点了，今天辛苦了",
